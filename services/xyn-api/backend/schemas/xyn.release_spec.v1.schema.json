{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Xyn Release Spec V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "name", "instance_ref", "parameters", "components"],
  "properties": {
    "schema_version": { "const": "xyn.release_spec.v1" },
    "name": { "type": "string", "minLength": 1 },
    "instance_ref": {
      "type": "object",
      "required": ["artifact_id"],
      "additionalProperties": false,
      "properties": {
        "artifact_id": { "type": "string", "minLength": 1 }
      }
    },
    "parameters": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "instance_label": { "type": "string" },
        "fqdn": { "type": "string" },
        "scheme": { "type": "string", "enum": ["http", "https"] },
        "ui_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "api_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "base_url": { "type": "string" },
        "dns": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "ttl": { "type": "integer", "minimum": 30, "maximum": 86400 }
          }
        }
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slug", "enabled"],
        "properties": {
          "slug": { "type": "string", "enum": ["xyn-ui", "xyn-api", "ems"] },
          "enabled": { "type": "boolean" },
          "image_ref": { "type": "string" },
          "env": { "type": "object", "additionalProperties": { "type": "string" } },
          "ports": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["container"],
              "properties": {
                "container": { "type": "integer", "minimum": 1, "maximum": 65535 },
                "host": { "type": "integer", "minimum": 1, "maximum": 65535 }
              }
            }
          }
        }
      }
    }
  }
}
