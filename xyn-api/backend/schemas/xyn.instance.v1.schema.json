{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Xyn Instance V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "name", "kind", "status", "network"],
  "properties": {
    "schema_version": { "const": "xyn.instance.v1" },
    "name": { "type": "string", "minLength": 1 },
    "kind": { "type": "string", "enum": ["ec2", "generic_host"] },
    "status": { "type": "string", "enum": ["running", "stopped", "unknown"] },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "public_ipv4": { "type": "string", "pattern": "^(?:[0-9]{1,3}\\.){3}[0-9]{1,3}$" },
        "public_hostname": { "type": "string", "minLength": 3 }
      },
      "anyOf": [
        { "required": ["public_ipv4"] },
        { "required": ["public_hostname"] }
      ]
    },
    "access": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ssh": {
          "type": "object",
          "additionalProperties": false,
          "required": ["host", "user"],
          "properties": {
            "host": { "type": "string", "minLength": 1 },
            "user": { "type": "string", "minLength": 1 },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "identity_ref": {
              "type": "object",
              "additionalProperties": false,
              "required": ["context_pack_id"],
              "properties": {
                "context_pack_id": { "type": "string", "format": "uuid" }
              }
            }
          }
        }
      }
    },
    "notes": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
